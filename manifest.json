{
  "manifest_version": 3,
  "name": "GramVault",
  "version": "0.3.0",
  "description": "Private grammar checker powered by local or cloud LLMs — your text never leaves your device",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://localhost:1234/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["rules.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "open-badge-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "MacCtrl+Shift+G"
      },
      "description": "Open grammar checker panel for focused field"
    }
  },
  "options_page": "dictionary.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
